    {
      "parameters": {
        "jsCode": "const payments = $input.first().json;\nif (!Array.isArray(payments) || payments.length === 0) return [];\n\nconst now = new Date();\nconst year = now.getUTCFullYear();\nconst month = now.getUTCMonth(); // 0-indexed\nconst billingMonth = `${year}-${String(month + 1).padStart(2, '0')}`;\nconst periodStart = new Date(Date.UTC(year, month, 1, 0, 0, 0)).toISOString();\n\nreturn payments.map(p => {\n  const planName = (p.plan_name || '').toLowerCase();\n  const isPremium = planName.includes('premium');\n  const includedMinutes = p.minutes ? parseInt(p.minutes) : (isPremium ? 1000 : 475);\n\n  return {\n    json: {\n      subscription_id: p.id,\n      agent_id: p.agent_id,\n      company_name: p.customer_name,\n      client_email: p.customer_email,\n      plan_type: isPremium ? 'premium' : 'standard',\n      included_minutes: includedMinutes,\n      billing_month: billingMonth,\n      period_start: periodStart\n    }\n  };\n});"
      },
      "id": "268c30cb-d39a-4b52-81cf-9daa4ac5a13c",
      "name": "Prepare Subscription Checks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://hgheyqwnrcvwtgngqdnq.supabase.co/rest/v1/hvac_call_log?agent_id=eq.{{ $json.agent_id }}&call_timestamp=gte.{{ $json.period_start }}&select=duration_seconds",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhnaGV5cXducmN2d3RnbmdxZG5xIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyOTUzNTIsImV4cCI6MjA4OTg3MTM1Mn0.dDzlIEgPvV2KVZOpCBYGbHJ2_LZnXoL6KKmQrAwfyL0"
            }
          ]
        },
        "options": {}
      },
      "id": "f6976942-1f1c-437d-be01-2b284c19422d",
      "name": "Supabase: Fetch Current Month Usage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        720,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "dSCVell30U6Yt1qA",
          "name": "Supabase Anon Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const calls = $input.first().json;\nconst sub = $('Prepare Subscription Checks').item;\n\nconst callList = Array.isArray(calls) ? calls : [];\nconst totalSeconds = callList.reduce((sum, c) => sum + (c.duration_seconds || 0), 0);\nconst totalMinutes = Math.ceil(totalSeconds / 60);\nconst includedMinutes = sub.json.included_minutes;\nconst usagePercent = includedMinutes > 0 ? Math.round((totalMinutes / includedMinutes) * 100) : 0;\nconst remainingMinutes = Math.max(0, includedMinutes - totalMinutes);\n\nreturn [{\n  json: {\n    ...sub.json,\n    total_minutes: totalMinutes,\n    usage_percent: usagePercent,\n    remaining_minutes: remainingMinutes,\n    needs_80_alert: usagePercent >= 80 && usagePercent < 100,\n    needs_100_alert: usagePercent >= 100,\n    overage_minutes: Math.max(0, totalMinutes - includedMinutes)\n  }\n}];"
      },
      "id": "d85df1ec-0379-4b23-bd02-9bb00e63757d",
      "name": "Calculate Usage %",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://hgheyqwnrcvwtgngqdnq.supabase.co/rest/v1/billing_cycles?agent_id=eq.{{ $json.agent_id }}&billing_month=eq.{{ $json.billing_month }}&select=alert_80_sent,alert_100_sent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhnaGV5cXducmN2d3RnbmdxZG5xIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyOTUzNTIsImV4cCI6MjA4OTg3MTM1Mn0.dDzlIEgPvV2KVZOpCBYGbHJ2_LZnXoL6KKmQrAwfyL0"
            }
          ]
        },
        "options": {}
      },
      "id": "46067c55-71da-410e-ac33-be56504b98fa",
      "name": "Supabase: Check If Alerts Already Sent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1200,
        0
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "dSCVell30U6Yt1qA",
          "name": "Supabase Anon Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const alertData = $input.first().json;\nconst usageData = $('Calculate Usage %').item.json;\n\nconst existing = Array.isArray(alertData) ? alertData[0] : alertData;\nconst alert80Sent = existing?.alert_80_sent || false;\nconst alert100Sent = existing?.alert_100_sent || false;\n\n// Determine which alert to send (if any)\nlet alertType = null;\nif (usageData.needs_100_alert && !alert100Sent) {\n  alertType = '100';\n} else if (usageData.needs_80_alert && !alert80Sent) {\n  alertType = '80';\n}\n\nif (!alertType) return []; // No alert needed\n\nreturn [{\n  json: {\n    ...usageData,\n    alert_type: alertType,\n    alert_80_sent: alert80Sent,\n    alert_100_sent: alert100Sent\n  }\n}];"
      },
      "id": "73efe797-4be4-4b2b-a207-9c003efeeb73",
      "name": "Determine Alert Needed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        0
      ]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.client_email }}",
        "subject": "={{ $json.alert_type === '100' ? '\u26a0\ufe0f Syntharra: You\\'ve exceeded your included minutes \u2014 ' : '\u26a1 Syntharra: 80% of included minutes used \u2014 ' }}{{ $json.company_name }}",
        "message": "=<div style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto'><div style='background:{{ $json.alert_type === '100' ? '#e53e3e' : '#dd6b20' }};padding:24px;border-radius:12px 12px 0 0'><h1 style='color:#fff;margin:0;font-size:20px'>{{ $json.alert_type === '100' ? '\u26a0\ufe0f Minutes Limit Exceeded' : '\u26a1 80% Usage Warning' }}</h1></div><div style='background:#f9f9f9;padding:24px;border:1px solid #e0e0e0'><p style='font-size:15px;color:#333'>Hi {{ $json.company_name }},</p>{{ $json.alert_type === '100' ? \"<p style='font-size:15px;color:#333'>Your AI Receptionist has <strong>exceeded the \" + $json.included_minutes + \" minutes</strong> included in your <strong>\" + $json.plan_type + \" plan</strong> this month.</p><p style='font-size:15px;color:#333'>You've used <strong>\" + $json.total_minutes + \" minutes</strong> so far, which is <strong>\" + $json.overage_minutes + \" minutes over</strong> your limit.</p><p style='font-size:15px;color:#e53e3e;font-weight:600'>Additional minutes are billed at $0.25/minute and will be invoiced at the end of the billing cycle.</p>\" : \"<p style='font-size:15px;color:#333'>Your AI Receptionist has used <strong>\" + $json.total_minutes + \" of \" + $json.included_minutes + \" minutes</strong> (\" + $json.usage_percent + \"%) included in your <strong>\" + $json.plan_type + \" plan</strong> this month.</p><p style='font-size:15px;color:#333'>You have approximately <strong>\" + $json.remaining_minutes + \" minutes remaining</strong>.</p>\" }}<div style='background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:16px;margin-top:16px'><p style='margin:0;font-size:14px;color:#666'><strong>Want more minutes?</strong> Upgrade to our Premium plan (1,000 min/mo) for better value. Contact us at <a href='mailto:daniel@syntharra.com'>daniel@syntharra.com</a>.</p></div></div><div style='padding:12px 24px;border:1px solid #e0e0e0;border-top:none;border-radius:0 0 12px 12px;text-align:center'><p style='color:#999;font-size:12px;margin:0'>Syntharra AI | <a href='mailto:daniel@syntharra.com'>daniel@syntharra.com</a></p></div></div>",
        "options": {}
      },
