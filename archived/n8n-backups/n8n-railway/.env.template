# =============================================================
# Syntharra n8n — Railway Environment Variables
# =============================================================
# Copy these into Railway Dashboard > Service > Variables
# Replace placeholder values with actual credentials
# =============================================================

# --- Database (Railway Postgres plugin auto-populates these) ---
# If using Railway's built-in Postgres, reference the plugin variables:
#   POSTGRES_HOST=${{Postgres.PGHOST}}
#   POSTGRES_PORT=${{Postgres.PGPORT}}
#   POSTGRES_DB=${{Postgres.PGDATABASE}}
#   POSTGRES_USER=${{Postgres.PGUSER}}
#   POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}

# If using external Postgres (e.g. Supabase):
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=

# --- Redis (Railway Redis plugin auto-populates) ---
# If using Railway's built-in Redis:
#   REDIS_HOST=${{Redis.REDISHOST}}
#   REDIS_PORT=${{Redis.REDISPORT}}
REDIS_HOST=
REDIS_PORT=6379

# --- n8n Core ---
N8N_HOST=n8n.syntharra.com
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=          # IMPORTANT: Generate once, never change. Use: openssl rand -hex 32
WEBHOOK_URL=https://n8n.syntharra.com/
GENERIC_TIMEZONE=America/New_York

# --- Execution ---
EXECUTIONS_MODE=queue
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168  # Hours (7 days). Increase if you need longer history.
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# --- Binary Data ---
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# --- Telemetry (disable for privacy) ---
N8N_DIAGNOSTICS_ENABLED=false

# --- Optional: SMTP for n8n error notifications ---
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=mail.smtp2go.com
# N8N_SMTP_PORT=2525
# N8N_SMTP_USER=
# N8N_SMTP_PASS=
# N8N_SMTP_SENDER=noreply@syntharra.com
