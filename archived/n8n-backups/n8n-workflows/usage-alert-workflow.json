padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#4A4A6A'>{{ $json.company_name }}</td></tr><tr style='border-bottom:1px solid #E5E7EB'><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#1A1A2E;width:38%;'>Plan</td><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#4A4A6A'>{{ $json.plan_type }}</td></tr><tr style='border-bottom:1px solid #E5E7EB'><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#1A1A2E;width:38%;background:#F7F7FB;'>Usage</td><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#4A4A6A'>{{ $json.usage_percent }}%</td></tr><tr style='border-bottom:1px solid #E5E7EB'><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#1A1A2E;width:38%;'>Minutes Used</td><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#4A4A6A'>{{ $json.total_minutes }} / {{ $json.included_minutes }}</td></tr>{{ $json.overage_minutes > 0 ? \"<tr style='border-bottom:1px solid #E5E7EB'><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#c53030;width:38%;background:#F7F7FB'>Overage</td><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#c53030;font-weight:700'>\" + $json.overage_minutes + \" min ($\" + (($json.overage_minutes * 25) / 100).toFixed(2) + \")</td></tr>\" : \"<tr><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;font-weight:700;color:#38a169;width:38%'>Remaining</td><td style='padding:9px 12px;font-family:Arial,sans-serif;font-size:13px;color:#38a169'>\" + $json.remaining_minutes + \" min</td></tr>\" }}</table></td></tr><tr><td style='border-top:1px solid #E5E7EB;padding:16px 32px;background:#F7F7FB;text-align:center'><p style='font-family:Arial,sans-serif;font-size:11px;color:#8A8AA0;margin:0'>Syntharra Internal &nbsp;·&nbsp; <a href='mailto:admin@syntharra.com' style='color:#6C63FF;text-decoration:none'>admin@syntharra.com</a></p></td></tr></table></td></tr></table></div>",
        "options": {}
