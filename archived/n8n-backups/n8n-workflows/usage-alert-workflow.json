        "message": "=<div style='margin:0;padding:0;background:#F7F7FB'><table width='100%' cellpadding='0' cellspacing='0' style='background:#F7F7FB;padding:24px 16px'><tr><td align='center'><table width='600' cellpadding='0' cellspacing='0' style='max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #E5E7EB'><tr><td style='background:{{ $json.alert_type === \"100\" ? \"linear-gradient(135deg,#c53030,#e53e3e)\" : \"linear-gradient(135deg,#dd6b20,#f6ad55)\" }};padding:28px 32px'><table cellpadding='0' cellspacing='0' border='0' style='border-collapse:collapse;margin-bottom:18px'><tr><td style='vertical-align:middle;padding-right:10px'><img src='data:image/png;base64,' width='36' height='36' alt='Syntharra' style='display:block;border:0;'/></td><td style='vertical-align:middle'><div style='font-family:Georgia,serif;font-size:20px;font-weight:normal;color:#ffffff;letter-spacing:0.5px;line-height:1.1'>Syntharra</div><div style='font-family:Arial,Helvetica,sans-serif;font-size:8px;font-weight:bold;color:rgba(255,255,255,0.7);letter-spacing:3.5px;text-transform:uppercase;margin-top:3px'>Global AI Solutions</div></td></tr></table><h1 style='font-family:Georgia,serif;font-size:22px;font-weight:normal;color:#ffffff;margin:0'>{{ $json.alert_type === \"100\" ? \"⚠️ Minutes Limit Exceeded\" : \"⚡ 80% Usage Warning\" }}</h1><p style='font-family:Arial,Helvetica,sans-serif;font-size:13px;color:rgba(255,255,255,0.75);margin:4px 0 0'>{{ $json.company_name }} &nbsp;·&nbsp; {{ $json.billing_month || \"This month\" }}</p></td></tr><tr><td style='padding:28px 32px'><p style='font-family:Arial,sans-serif;font-size:14px;color:#4A4A6A;margin:0 0 16px'>Hi {{ $json.company_name }},</p>{{ $json.alert_type === \"100\" ? \"<p style='font-family:Arial,sans-serif;font-size:14px;color:#4A4A6A;margin:0 0 16px'>Your AI Receptionist has <strong style=\\\"color:#1A1A2E\\\">exceeded the \" + $json.included_minutes + \" minutes</strong> included in your <strong style=\\\"color:#1A1A2E\\\">\" + $json.plan_type + \" plan</strong> this month.</p><p style='font-family:Arial,sans-serif;font-size:14px;color:#4A4A6A;margin:0 0 16px'>You've used <strong style=\\\"color:#1A1A2E\\\">\" + $json.total_minutes + \" minutes</strong> — <strong style=\\\"color:#c53030\\\">\" + $json.overage_minutes + \" minutes over</strong> your limit.</p><div style='background:#FFF5F5;border:1px solid #FEB2B2;border-radius:8px;padding:14px;font-family:Arial,sans-serif;font-size:13px;color:#c53030;font-weight:700;margin-bottom:20px'>Additional minutes are billed at $0.25/min and invoiced at end of billing cycle.</div>\" : \"<p style='font-family:Arial,sans-serif;font-size:14px;color:#4A4A6A;margin:0 0 16px'>Your AI Receptionist has used <strong style=\\\"color:#1A1A2E\\\">\" + $json.total_minutes + \" of \" + $json.included_minutes + \" minutes</strong> (\" + $json.usage_percent + \"%) included in your <strong style=\\\"color:#1A1A2E\\\">\" + $json.plan_type + \" plan</strong> this month.</p><p style='font-family:Arial,sans-serif;font-size:14px;color:#4A4A6A;margin:0 0 16px'>You have approximately <strong style=\\\"color:#1A1A2E\\\">\" + $json.remaining_minutes + \" minutes remaining</strong>.</p>\" }}<div style='background:#F7F7FB;border:1px solid #E5E7EB;border-radius:8px;padding:14px;font-family:Arial,sans-serif;font-size:13px;color:#4A4A6A'><strong style='color:#1A1A2E'>Want more minutes?</strong> Upgrade to Premium (1,000 min/mo) for better value. Contact <a href='mailto:support@syntharra.com' style='color:#6C63FF;text-decoration:none'>support@syntharra.com</a>.</div></td></tr><tr><td style='border-top:1px solid #E5E7EB;padding:16px 32px;background:#F7F7FB;text-align:center'><p style='font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#8A8AA0;margin:0'>Questions? <a href='mailto:support@syntharra.com' style='color:#6C63FF;text-decoration:none'>support@syntharra.com</a> &nbsp;·&nbsp; <a href='https://www.syntharra.com' style='color:#6C63FF;text-decoration:none'>www.syntharra.com</a></p><p style='font-family:Arial,Helvetica,sans-serif;font-size:10px;color:#8A8AA0;letter-spacing:1px;text-transform:uppercase;margin:6px 0 0'>AI Solutions for the Trade Industry</p></td></tr></table></td></tr></table></div>",
        "options": {}
