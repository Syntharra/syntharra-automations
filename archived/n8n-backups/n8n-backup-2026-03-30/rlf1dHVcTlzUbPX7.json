    },
    {
      "id": "sub-trans",
      "name": "Get Transcript",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -960,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://syntharra.app.n8n.cloud/webhook/generate-scenario-transcript",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ agent_greeting: $json.greeting, caller_persona: $json.persona }) }}",
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "sub-fire",
      "name": "Fire Call Processor",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -720,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "https://syntharra.app.n8n.cloud/webhook/retell-hvac-webhook",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ event: \"call_analyzed\", call: { call_id: $(\"Workflow Input Trigger\").item.json.callId, agent_id: \"agent_d180e1bd5b9b724c8f616a0415\", from_number: \"+15555550199\", to_number: \"+18129944371\", start_timestamp: 1711450000000, end_timestamp: 1711450180000, disconnection_reason: \"user_hangup\", call_analysis: {}, transcript: $json.transcript } }) }}",
        "options": {
          "timeout": 15000
        }
      }
    },
    {
      "id": "sub-wait",
      "name": "Wait 25s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        -480,
        0
      ],
      "parameters": {
        "resume": "timeInterval",
        "amount": 25,
        "unit": "seconds"
      }
    },
    {
      "id": "sub-check",
      "name": "Check Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -240,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://hgheyqwnrcvwtgngqdnq.supabase.co/rest/v1/hvac_call_log?call_id=eq.{{ $(\"Workflow Input Trigger\").item.json.callId }}&select=call_id,caller_name,service_requested,is_lead,lead_score,summary",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhnaGV5cXducmN2d3RnbmdxZG5xIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDI5NTM1MiwiZXhwIjoyMDg5ODcxMzUyfQ.PENNZ2K5syVFyU3Yn6FfYZP1JEtmanlV6nTrlGaeqsg"
            },
            {
              "name": "Authorization",
              "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhnaGV5cXducmN2d3RnbmdxZG5xIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDI5NTM1MiwiZXhwIjoyMDg5ODcxMzUyfQ.PENNZ2K5syVFyU3Yn6FfYZP1JEtmanlV6nTrlGaeqsg"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "sub-score",
      "name": "Score Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst inp = $('Workflow Input Trigger').item.json;\nconst rows = $input.all().map(i => i.json);\nconst log = (Array.isArray(rows) && rows.length > 0 && rows[0].call_id) ? rows[0] : null;\nconst failures = [];\nif (!log) { failures.push('Not logged in Supabase'); }\nelse {\n  if (!!log.is_lead !== inp.expectLead) failures.push('is_lead=' + log.is_lead + ' expected ' + inp.expectLead);\n  if (inp.expectLead && (log.lead_score || 0) < inp.minScore) failures.push('score=' + log.lead_score + ' expected >=' + inp.minScore);\n}\nreturn [{ json: { sid: inp.sid, name: inp.name, status: failures.length ? 'FAIL' : 'PASS', failures, is_lead: log ? log.is_lead : null, lead_score: log ? log.lead_score : null, service: log ? log.service_requested : null, caller_name: log ? log.caller_name : null, summary: log ? (log.summary||'').slice(0,100) : '', callId: inp.callId } }];\n"
      }
    },
    {
      "id": "sub-del",
      "name": "Delete Test Log",
      "type": "n8n-nodes-base.httpRequest",
