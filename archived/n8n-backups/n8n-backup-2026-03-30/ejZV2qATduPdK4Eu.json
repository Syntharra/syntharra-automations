        "responseBody": "=<!DOCTYPE html><html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1'><title>Unsubscribed</title></head><body style='margin:0;padding:60px 20px;background:#F7F7FB;font-family:Helvetica,Arial,sans-serif;text-align:center'><div style='max-width:400px;margin:0 auto;background:#fff;border-radius:16px;padding:40px 32px;border:1px solid #E5E7EB'><div style='font-size:36px;margin-bottom:16px'>\u2713</div><h1 style='font-size:20px;font-weight:700;color:#1A1A2E;margin:0 0 8px'>You've been unsubscribed</h1><p style='font-size:14px;color:#4A4A6A;line-height:1.6;margin:0 0 24px'>You won't receive any more weekly emails from Syntharra. We're sorry to see you go.</p><a href='https://syntharra.com' style='font-size:13px;color:#6C63FF;text-decoration:none;font-weight:600'>Back to syntharra.com \u2192</a></div></body></html>",
