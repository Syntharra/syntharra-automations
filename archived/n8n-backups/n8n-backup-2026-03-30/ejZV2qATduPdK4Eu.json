    {
      "parameters": {
        "jsCode": "// Mark email as unsubscribed in Supabase\nconst email = $input.first().json.query?.email;\nif (!email) {\n  return [{json: {success: false, message: 'No email provided'}}];\n}\n\ntry {\n  const resp = await fetch(`https://hgheyqwnrcvwtgngqdnq.supabase.co/rest/v1/website_leads?email=eq.${encodeURIComponent(email)}`, {\n    method: 'PATCH',\n    headers: {\n      'Content-Type': 'application/json',\n      'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhnaGV5cXducmN2d3RnbmdxZG5xIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyOTUzNTIsImV4cCI6MjA4OTg3MTM1Mn0.dDzlty1DaJtgKEMOLMEkC0VCGhrlKbI0R4DNOPkNPWo',\n      'Prefer': 'return=minimal'\n    },\n    body: JSON.stringify({ source: 'unsubscribed' })\n  });\n  return [{json: {success: true, email}}];\n} catch(e) {\n  return [{json: {success: false, error: e.message}}];\n}"
      },
      "name": "Update Supabase",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
