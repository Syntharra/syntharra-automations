{
  "meta": {
    "description": "Syntharra — HVAC Standard Onboarding Pack Email Node",
    "usage": "Add this as a new node in the HVAC Std Onboarding workflow (4Hx7aRdzMl5N0uJP). Wire it after the 'You Are Live' node, or use it as the standalone 'Onboarding Pack' send step. All {{variables}} are resolved from prior nodes in the workflow.",
    "variables_required": [
      "company_name",
      "first_name",
      "agent_name",
      "ai_phone_number",
      "ai_phone_number_digits — same as ai_phone_number but digits only, e.g. 18129944371",
      "transfer_phone_number",
      "notification_email",
      "agent_id"
    ]
  },
  "node": {
    "id": "onboarding-pack-standard-smtp",
    "name": "Send Onboarding Pack (Standard)",
    "type": "n8n-nodes-base.httpRequest",
    "typeVersion": 3,
    "position": [1200, 300],
    "parameters": {
      "method": "POST",
      "url": "https://api.smtp2go.com/v3/email/send",
      "authentication": "none",
      "sendHeaders": true,
      "headerParameters": {
        "parameters": [
          { "name": "Content-Type", "value": "application/json" }
        ]
      },
      "sendBody": true,
      "bodyContentType": "json",
      "jsonBody": "={{ JSON.stringify({ \"api_key\": $('Get SMTP2GO Key').item.json.key_value, \"to\": [{\"email\": $json.notification_email, \"name\": $json.company_name}], \"sender\": \"Syntharra <noreply@syntharra.com>\", \"subject\": \"Your AI Receptionist is Live — Onboarding Pack 📋\", \"html_body\": buildOnboardingPackStandard($json) }) }}",
      "options": {}
    },
    "notes": "Uses SMTP2GO REST API. Credential: query syntharra_vault for smtp2go api_key. The html_body is built by the Code node preceding this one."
  },
  "companion_code_node": {
    "id": "build-onboarding-html-standard",
    "name": "Build Standard Onboarding Pack HTML",
    "type": "n8n-nodes-base.code",
    "typeVersion": 2,
    "position": [1000, 300],
    "parameters": {
      "mode": "runOnceForEachItem",
      "jsCode": "// ═══════════════════════════════════════════════════════════\n// Syntharra — Standard Onboarding Pack HTML Builder\n// ═══════════════════════════════════════════════════════════\n\nconst d = $input.item.json;\n\nconst company_name         = d.company_name || 'Your Company';\nconst first_name           = d.first_name || company_name;\nconst agent_name           = d.agent_name || 'Your AI Receptionist';\nconst ai_phone_number      = d.ai_phone_number || '';\nconst ai_phone_digits      = ai_phone_number.replace(/\\D/g, '');\nconst transfer_phone       = d.transfer_phone_number || '';\nconst notification_email   = d.notification_email || '';\nconst agent_id             = d.agent_id || '';\nconst dashboard_url        = `https://syntharra.com/dashboard.html?agent_id=${agent_id}`;\n\nconst ICON_URL = 'https://raw.githubusercontent.com/Syntharra/syntharra-website/main/logo-icon-2x.png';\n\nconst html = `<!DOCTYPE html>\n<html lang=\"en\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\"></head>\n<body style=\"margin:0;padding:0;background:#F7F7FB;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;\">\n<div style=\"display:none;max-height:0;overflow:hidden;color:#F7F7FB;\">Your AI Receptionist is live. Here's everything you need to know. &#8203;&#8203;&#8203;&#8203;&#8203;</div>\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F7F7FB;padding:40px 20px;\">\n  <tr><td align=\"center\">\n  <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;background:#ffffff;border-radius:20px;border:1px solid #E5E7EB;overflow:hidden;\">\n\n  <!-- HEADER -->\n  <tr><td style=\"background:linear-gradient(135deg,#6C63FF 0%,#4F46E5 50%,#00D4FF 100%);padding:40px 40px 32px;text-align:center;\">\n    <table cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 auto 20px;\">\n      <tr>\n        <td style=\"vertical-align:middle;padding-right:10px;\"><img src=\"${ICON_URL}\" alt=\"\" width=\"40\" height=\"40\" style=\"display:block;border:0;\"></td>\n        <td style=\"vertical-align:middle;text-align:left;\">\n          <div style=\"font-size:18px;font-weight:700;color:#fff;line-height:1;\">Syntharra</div>\n          <div style=\"font-size:8px;font-weight:600;letter-spacing:1.4px;color:rgba(255,255,255,0.75);text-transform:uppercase;margin-top:3px;\">Global AI Solutions</div>\n        </td>\n      </tr>\n    </table>\n    <div style=\"display:inline-block;background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.3);border-radius:100px;padding:6px 16px;margin-bottom:16px;\">\n      <span style=\"font-size:11px;font-weight:600;letter-spacing:1px;color:#fff;text-transform:uppercase;\">Standard Plan &middot; Active</span>\n    </div>\n    <h1 style=\"margin:0 0 10px;font-size:28px;font-weight:800;color:#fff;letter-spacing:-0.5px;line-height:1.2;\">Welcome Aboard, ${company_name}! &#127881;</h1>\n    <p style=\"margin:0;font-size:15px;color:rgba(255,255,255,0.85);line-height:1.5;\">Your AI Receptionist is live and answering calls.<br>Here's your complete onboarding pack.</p>\n  </td></tr>\n\n  <!-- STAT ROW -->\n  <tr><td style=\"padding:0 40px;background:#fff;\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:32px 0 0;border:1px solid #E5E7EB;border-radius:14px;overflow:hidden;\">\n      <tr>\n        <td width=\"33%\" style=\"padding:20px 16px;text-align:center;border-right:1px solid #E5E7EB;\">\n          <div style=\"font-size:22px;font-weight:800;color:#6C63FF;margin-bottom:4px;\">24/7</div>\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.5px;color:#8A8AA0;text-transform:uppercase;\">Always On</div>\n        </td>\n        <td width=\"33%\" style=\"padding:20px 16px;text-align:center;border-right:1px solid #E5E7EB;\">\n          <div style=\"font-size:22px;font-weight:800;color:#6C63FF;margin-bottom:4px;\">475</div>\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.5px;color:#8A8AA0;text-transform:uppercase;\">Monthly Minutes</div>\n        </td>\n        <td width=\"33%\" style=\"padding:20px 16px;text-align:center;\">\n          <div style=\"font-size:22px;font-weight:800;color:#6C63FF;margin-bottom:4px;\">&lt;2s</div>\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.5px;color:#8A8AA0;text-transform:uppercase;\">Answer Time</div>\n        </td>\n      </tr>\n    </table>\n  </td></tr>\n\n  <!-- BODY -->\n  <tr><td style=\"padding:32px 40px 0;\">\n    <p style=\"margin:0 0 24px;font-size:15px;color:#4A4A6A;line-height:1.7;\">Hi ${first_name}, your AI Receptionist is now live and ready to handle every inbound call for <strong style=\"color:#1A1A2E;\">${company_name}</strong>. Here's everything you need to know right from day one.</p>\n\n    <!-- AI Details -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:24px;\">\n      <tr><td style=\"padding:24px;background:#F7F7FB;border-radius:14px;border-left:4px solid #6C63FF;\">\n        <div style=\"font-size:13px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#6C63FF;margin-bottom:12px;\">&#128241; Your AI Receptionist Details</div>\n        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n          <tr><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;\"><span style=\"font-size:13px;color:#8A8AA0;\">Agent Name</span></td><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;text-align:right;\"><strong style=\"font-size:14px;color:#1A1A2E;\">${agent_name}</strong></td></tr>\n          <tr><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;\"><span style=\"font-size:13px;color:#8A8AA0;\">AI Phone Number</span></td><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;text-align:right;\"><strong style=\"font-size:14px;color:#1A1A2E;\">${ai_phone_number}</strong></td></tr>\n          <tr><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;\"><span style=\"font-size:13px;color:#8A8AA0;\">Plan</span></td><td style=\"padding:6px 0;border-bottom:1px solid #E5E7EB;text-align:right;\"><strong style=\"font-size:14px;color:#1A1A2E;\">Standard &middot; 475 min/mo</strong></td></tr>\n          <tr><td style=\"padding:6px 0;\"><span style=\"font-size:13px;color:#8A8AA0;\">Live Transfer Number</span></td><td style=\"padding:6px 0;text-align:right;\"><strong style=\"font-size:14px;color:#1A1A2E;\">${transfer_phone}</strong></td></tr>\n        </table>\n      </td></tr>\n    </table>\n\n    <!-- Call Forwarding -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:24px;\">\n      <tr><td style=\"padding:24px;background:#fff8f0;border-radius:14px;border:1px solid #FFD9A0;border-left:4px solid #FF9500;\">\n        <div style=\"font-size:13px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#FF6B00;margin-bottom:12px;\">&#128222; How to Set Up Call Forwarding</div>\n        <p style=\"margin:0 0 14px;font-size:14px;color:#4A4A6A;line-height:1.6;\">Forward your business number to your AI phone number. Takes under 2 minutes.</p>\n        <div style=\"background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #E5E7EB;margin-bottom:10px;\">\n          <div style=\"font-size:12px;font-weight:700;color:#1A1A2E;margin-bottom:6px;\">&#63743; iPhone</div>\n          <div style=\"font-size:13px;color:#4A4A6A;\">Settings &#8594; Phone &#8594; Call Forwarding &#8594; ON &#8594; Enter <strong style=\"color:#6C63FF;\">${ai_phone_number}</strong></div>\n        </div>\n        <div style=\"background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #E5E7EB;margin-bottom:10px;\">\n          <div style=\"font-size:12px;font-weight:700;color:#1A1A2E;margin-bottom:6px;\">&#129302; Android</div>\n          <div style=\"font-size:13px;color:#4A4A6A;\">Phone app &#8594; &#8942; Settings &#8594; Calls &#8594; Call Forwarding &#8594; Always Forward &#8594; <strong style=\"color:#6C63FF;\">${ai_phone_number}</strong></div>\n        </div>\n        <div style=\"background:#1A1A2E;border-radius:10px;padding:12px 16px;\">\n          <div style=\"font-size:11px;font-weight:700;color:#00D4FF;letter-spacing:0.8px;margin-bottom:6px;\">ANY PHONE &#8212; DIAL THIS CODE:</div>\n          <div style=\"font-family:monospace;font-size:15px;color:#fff;letter-spacing:1px;\">*72${ai_phone_digits}</div>\n          <div style=\"font-size:11px;color:rgba(255,255,255,0.5);margin-top:4px;\">To cancel: dial *73</div>\n        </div>\n        <p style=\"margin:12px 0 0;font-size:12px;color:#8A8AA0;font-style:italic;\">&#128161; On a VoIP/office system? Ask your provider to set unconditional call forwarding to ${ai_phone_number}.</p>\n      </td></tr>\n    </table>\n\n    <!-- How Calls Work -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:24px;\">\n      <tr><td style=\"padding:24px;background:#F7F7FB;border-radius:14px;border-left:4px solid #00D4FF;\">\n        <div style=\"font-size:13px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#00B8E0;margin-bottom:16px;\">&#128260; What Happens on Every Call</div>\n        <table width=\"100%\"><tr><td style=\"padding:0 0 12px;\"><table cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"vertical-align:top;padding-right:12px;\"><div style=\"width:26px;height:26px;background:#6C63FF;border-radius:50%;text-align:center;line-height:26px;font-size:11px;font-weight:800;color:#fff;\">1</div></td><td><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:2px;\">Customer calls your business number</div><div style=\"font-size:13px;color:#4A4A6A;\">Instantly forwarded to your AI Receptionist.</div></td></tr></table></td></tr>\n        <tr><td style=\"padding:0 0 12px;\"><table cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"vertical-align:top;padding-right:12px;\"><div style=\"width:26px;height:26px;background:#6C63FF;border-radius:50%;text-align:center;line-height:26px;font-size:11px;font-weight:800;color:#fff;\">2</div></td><td><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:2px;\">${agent_name} answers within 2 seconds</div><div style=\"font-size:13px;color:#4A4A6A;\">Handles their enquiry, collects job details, address, and urgency.</div></td></tr></table></td></tr>\n        <tr><td style=\"padding:0 0 12px;\"><table cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"vertical-align:top;padding-right:12px;\"><div style=\"width:26px;height:26px;background:#6C63FF;border-radius:50%;text-align:center;line-height:26px;font-size:11px;font-weight:800;color:#fff;\">3</div></td><td><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:2px;\">You get a notification instantly</div><div style=\"font-size:13px;color:#4A4A6A;\">Full call summary emailed to ${notification_email} right after every call.</div></td></tr></table></td></tr>\n        <tr><td style=\"padding:0;\"><table cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"vertical-align:top;padding-right:12px;\"><div style=\"width:26px;height:26px;background:#00D4FF;border-radius:50%;text-align:center;line-height:26px;font-size:11px;font-weight:800;color:#fff;\">&#10003;</div></td><td><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:2px;\">You follow up on your schedule</div><div style=\"font-size:13px;color:#4A4A6A;\">Every job detail captured before you call them back.</div></td></tr></table></td></tr></table>\n      </td></tr>\n    </table>\n\n    <!-- FAQs -->\n    <div style=\"margin-bottom:24px;\">\n      <div style=\"font-size:15px;font-weight:700;color:#1A1A2E;margin-bottom:14px;\">&#10067; Common Questions</div>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:10px;\"><tr><td style=\"padding:14px 16px;background:#F7F7FB;border-radius:10px;border:1px solid #E5E7EB;\"><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:5px;\">Where do missed calls go?</div><div style=\"font-size:13px;color:#4A4A6A;line-height:1.6;\">There are no missed calls. Your AI answers every call 24/7. You receive a full summary at ${notification_email} after every single call.</div></td></tr></table>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:10px;\"><tr><td style=\"padding:14px 16px;background:#F7F7FB;border-radius:10px;border:1px solid #E5E7EB;\"><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:5px;\">Can customers reach me directly?</div><div style=\"font-size:13px;color:#4A4A6A;line-height:1.6;\">Yes. Any caller can ask to speak to someone and your AI will live-transfer them to <strong>${transfer_phone}</strong> immediately.</div></td></tr></table>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:10px;\"><tr><td style=\"padding:14px 16px;background:#F7F7FB;border-radius:10px;border:1px solid #E5E7EB;\"><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:5px;\">What if my AI can't answer something?</div><div style=\"font-size:13px;color:#4A4A6A;line-height:1.6;\">It takes the caller's details and lets them know someone will follow up. Nothing falls through the cracks.</div></td></tr></table>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:14px 16px;background:#F7F7FB;border-radius:10px;border:1px solid #E5E7EB;\"><div style=\"font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:5px;\">What counts toward my 475 minutes?</div><div style=\"font-size:13px;color:#4A4A6A;line-height:1.6;\">Only actual AI talk time. We alert you at 80% usage. Overages billed at a low per-minute rate. Usage resets each billing cycle.</div></td></tr></table>\n    </div>\n\n    <!-- Dashboard CTA -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:28px;\">\n      <tr><td style=\"padding:24px;background:linear-gradient(135deg,#f5f4ff 0%,#eef9ff 100%);border-radius:14px;border:1px solid #D4D0FF;text-align:center;\">\n        <div style=\"font-size:15px;font-weight:700;color:#1A1A2E;margin-bottom:6px;\">View Your Live Dashboard</div>\n        <div style=\"font-size:13px;color:#4A4A6A;margin-bottom:16px;\">Track every call, view summaries, and monitor your AI in real time.</div>\n        <a href=\"${dashboard_url}\" style=\"display:inline-block;background:#6C63FF;color:#fff;font-weight:700;font-size:14px;padding:13px 28px;border-radius:10px;text-decoration:none;\">Open My Dashboard &#8594;</a>\n      </td></tr>\n    </table>\n\n    <!-- Checklist -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:28px;\">\n      <tr><td style=\"padding:20px;background:#fff;border-radius:12px;border:1px solid #E5E7EB;\">\n        <div style=\"font-size:13px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#1A1A2E;margin-bottom:14px;\">&#9989; Your Quick Start Checklist</div>\n        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n          <tr><td style=\"padding:5px 0;font-size:13px;color:#4A4A6A;border-bottom:1px solid #F0F0F7;\">&#9744; &nbsp;Set up call forwarding to <strong style=\"color:#6C63FF;\">${ai_phone_number}</strong></td></tr>\n          <tr><td style=\"padding:5px 0;font-size:13px;color:#4A4A6A;border-bottom:1px solid #F0F0F7;\">&#9744; &nbsp;Call your own number and hear your AI in action</td></tr>\n          <tr><td style=\"padding:5px 0;font-size:13px;color:#4A4A6A;border-bottom:1px solid #F0F0F7;\">&#9744; &nbsp;Open your dashboard at syntharra.com/dashboard</td></tr>\n          <tr><td style=\"padding:5px 0;font-size:13px;color:#4A4A6A;\">&#9744; &nbsp;Bookmark support@syntharra.com for anything you need</td></tr>\n        </table>\n      </td></tr>\n    </table>\n\n  </td></tr>\n\n  <!-- SUPPORT -->\n  <tr><td style=\"padding:0 40px 32px;\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"padding:18px;background:#1A1A2E;border-radius:12px;text-align:center;\">\n      <p style=\"margin:0 0 6px;font-size:13px;color:rgba(255,255,255,0.6);\">Questions? We're here.</p>\n      <a href=\"mailto:support@syntharra.com\" style=\"font-size:14px;font-weight:700;color:#00D4FF;text-decoration:none;\">support@syntharra.com</a>\n    </td></tr></table>\n  </td></tr>\n\n  <!-- FOOTER -->\n  <tr><td style=\"padding:20px 40px;border-top:1px solid #E5E7EB;text-align:center;\">\n    <p style=\"margin:0 0 6px;font-size:11px;color:#8A8AA0;\">&#169; 2025 Syntharra &middot; Global AI Solutions &middot; <a href=\"https://syntharra.com\" style=\"color:#6C63FF;text-decoration:none;\">syntharra.com</a></p>\n    <p style=\"margin:0;font-size:11px;color:#B0B0C3;\">You're receiving this because you signed up for Syntharra Standard.</p>\n  </td></tr>\n\n  </table>\n  </td></tr>\n</table>\n</body>\n</html>`;\n\nreturn { ...d, onboarding_pack_html: html };"
    }
  }
}
