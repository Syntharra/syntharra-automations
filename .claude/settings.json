{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_retell_write.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_token_scan.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/post_n8n_webhook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/stop_session_log.py"
          }
        ]
      }
    ]
  }
}