{
  "name": "Monthly Minutes Calculator & Overage Billing",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 8,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "schedule_trigger",
      "name": "Monthly Trigger (1st of Month 8AM UTC)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        200,
        400
      ],
      "notes": "Runs daily at 8AM UTC. The first Code node checks if today is the 1st of the month."
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Only proceed on the 1st of the month\nconst now = new Date();\nconst dayOfMonth = now.getUTCDate();\n\nif (dayOfMonth !== 1) {\n  // Not the 1st — skip execution\n  return [];\n}\n\n// Calculate PREVIOUS month's billing period\nconst year = now.getUTCMonth() === 0 ? now.getUTCFullYear() - 1 : now.getUTCFullYear();\nconst month = now.getUTCMonth() === 0 ? 12 : now.getUTCMonth(); // getUTCMonth is 0-indexed\nconst billingMonth = `${year}-${String(month).padStart(2, '0')}`;\n\nconst periodStart = new Date(Date.UTC(year, month - 1, 1, 0, 0, 0)).toISOString();\nconst periodEnd = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 1, 0, 0, 0)).toISOString();\n\nreturn [{\n  json: {\n    billing_month: billingMonth,\n    period_start: periodStart,\n    period_end: periodEnd,\n    run_date: now.toISOString()\n  }\n}];"
      },
      "id": "check_first_of_month",
      "name": "Check: 1st of Month & Calc Period",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
