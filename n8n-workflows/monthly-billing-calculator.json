    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const calls = $input.first().json;\nconst sub = $('Split Into Individual Subscriptions').item;\n\n// Calculate totals\nconst callList = Array.isArray(calls) ? calls : [];\nconst totalCalls = callList.length;\nconst totalSeconds = callList.reduce((sum, c) => sum + (c.duration_seconds || 0), 0);\nconst totalMinutes = Math.ceil(totalSeconds / 60); // Round UP to nearest minute\nconst includedMinutes = sub.json.included_minutes;\n\n// Overage calculation\nconst overageMinutes = Math.max(0, totalMinutes - includedMinutes);\nconst overageRateCents = sub.json.overage_rate_cents || 25;\nconst overageAmountCents = overageMinutes * overageRateCents;\n\nconst usagePercent = includedMinutes > 0 ? Math.round((totalMinutes / includedMinutes) * 100) : 0;\n\nreturn [{\n  json: {\n    ...sub.json,\n    total_calls: totalCalls,\n    total_seconds: totalSeconds,\n    total_minutes: totalMinutes,\n    included_minutes: includedMinutes,\n    overage_minutes: overageMinutes,\n    overage_rate_cents: overageRateCents,\n    overage_amount_cents: overageAmountCents,\n    overage_amount_dollars: (overageAmountCents / 100).toFixed(2),\n    usage_percent: usagePercent,\n    has_overage: overageMinutes > 0\n  }\n}];"
      },
