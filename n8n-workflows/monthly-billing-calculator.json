        "url": "=https://hgheyqwnrcvwtgngqdnq.supabase.co/rest/v1/hvac_call_log?agent_id=eq.{{ $json.agent_id }}&call_timestamp=gte.{{ $json.period_start }}&call_timestamp=lt.{{ $json.period_end }}&select=duration_seconds,call_id,call_timestamp",
        "authentication": "genericCredentialType",
