    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const payments = $input.first().json;\nconst billingData = $('Check: 1st of Month & Calc Period').first().json;\n\nif (!Array.isArray(payments) || payments.length === 0) {\n  return [{ json: { error: 'No active subscriptions found', ...billingData } }];\n}\n\n// Map stripe_payment_data fields to billing fields\nreturn payments.map(p => {\n  // Determine plan type and included minutes from the payment data\n  const planName = (p.plan_name || '').toLowerCase();\n  const isPremuim = planName.includes('premium');\n  const includedMinutes = p.minutes ? parseInt(p.minutes) : (isPremuim ? 1000 : 475);\n\n  return {\n    json: {\n      ...billingData,\n      subscription_id: p.id,\n      agent_id: p.agent_id,\n      company_name: p.customer_name,\n      client_email: p.customer_email,\n      plan_type: isPremuim ? 'premium' : 'standard',\n      included_minutes: includedMinutes,\n      overage_rate_cents: 25,\n      stripe_customer_id: p.stripe_customer_id,\n      stripe_subscription_id: p.stripe_subscription_id\n    }\n  };\n});"
      },
      "id": "split_subscriptions",
      "name": "Split Into Individual Subscriptions",
      "type": "n8n-nodes-base.code",
