# Syntharra OAuth Server Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000

# Supabase
SUPABASE_URL=https://hgheyqwnrcvwtgngqdnq.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# Google OAuth (create at console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.syntharra.com/callback

# Microsoft OAuth (create at portal.azure.com → App registrations)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://auth.syntharra.com/callback

# Calendly OAuth (create at developer.calendly.com)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Jobber OAuth (create at developer.getjobber.com)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# Housecall Pro OAuth
HCP_CLIENT_ID=
HCP_CLIENT_SECRET=

# HubSpot OAuth (create at developers.hubspot.com)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# GoHighLevel OAuth (create at marketplace.gohighlevel.com)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
