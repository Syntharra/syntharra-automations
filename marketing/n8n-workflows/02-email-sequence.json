    },
    {
      "parameters": {
        "fromEmail": "solutions@syntharra.com",
        "fromName": "Dan at Syntharra",
        "toEmail": "={{ $json.email }}",
        "subject": "Last message from me",
        "emailType": "html",
        "message": "<!DOCTYPE html><html><head><meta charset='UTF-8'></head><body style='margin:0;padding:0;background:#F7F7FB;font-family:Inter,Arial,sans-serif;'><table width='100%' cellpadding='0' cellspacing='0' style='background:#F7F7FB;padding:32px 16px;'><tr><td align='center'><table width='560' cellpadding='0' cellspacing='0' style='background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #E5E7EB;'><tr><td style='background:#6C63FF;padding:24px 32px;'><span style='color:#ffffff;font-size:20px;font-weight:700;'>Syntharra</span><span style='color:rgba(255,255,255,0.6);font-size:11px;letter-spacing:2px;text-transform:uppercase;margin-left:8px;'>AI SOLUTIONS</span></td></tr><tr><td style='padding:32px;'><p style='margin:0 0 16px;color:#1A1A2E;font-size:15px;line-height:1.6;'>This is my last email — I don't want to clog your inbox.</p><p style='margin:0 0 16px;color:#1A1A2E;font-size:15px;line-height:1.6;'>Just one question: is missing after-hours calls actually a problem for <strong>{{ $json.business_name }}</strong>, or is it covered?</p><p style='margin:0 0 24px;color:#4A4A6A;font-size:15px;line-height:1.6;'>Reply <strong>\"yes\"</strong> and I'll send over a 2-minute demo. Reply <strong>\"no\"</strong> and I'll stop emailing. Either way, I'll respect it.</p><table cellpadding='0' cellspacing='0'><tr><td style='background:#6C63FF;border-radius:8px;padding:12px 24px;'><a href='https://syntharra.com/demo?ref={{ $json.id }}&intent=yes' style='color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;'>Yes, show me the demo</a></td><td width='12'></td><td style='background:#F7F7FB;border:1px solid #E5E7EB;border-radius:8px;padding:12px 24px;'><a href='https://syntharra.com/unsubscribe?ref={{ $json.id }}' style='color:#4A4A6A;font-size:14px;font-weight:600;text-decoration:none;'>No thanks</a></td></tr></table></td></tr><tr><td style='padding:20px 32px;border-top:1px solid #E5E7EB;'><p style='margin:0;color:#8A8AA0;font-size:12px;'>Syntharra Global AI Solutions &nbsp;·&nbsp; <a href='mailto:solutions@syntharra.com' style='color:#6C63FF;text-decoration:none;'>solutions@syntharra.com</a> &nbsp;·&nbsp; <a href='https://syntharra.com/unsubscribe?ref={{ $json.id }}' style='color:#8A8AA0;text-decoration:none;'>Unsubscribe</a></p></td></tr></table></td></tr></table></body></html>",
        "options": {}
      },
      "id": "node-send-email3",
      "name": "Send Email 3",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [680, 660],
      "credentials": {
        "smtp": {
          "name": "SMTP2GO - Syntharra"
        }
      }
    }
  ],
  "connections": {
    "Hourly Trigger": {
      "main": [
        [
          { "node": "Get New Leads", "type": "main", "index": 0 },
          { "node": "Get Day-3 Leads", "type": "main", "index": 0 },
          { "node": "Get Day-7 Leads", "type": "main", "index": 0 }
        ]
      ]
    },
    "Get New Leads": {
      "main": [[{ "node": "Has New Leads?", "type": "main", "index": 0 }]]
    },
    "Has New Leads?": {
      "main": [
        [{ "node": "Prepare Email Variables", "type": "main", "index": 0 }],
        []
      ]
    },
    "Prepare Email Variables": {
      "main": [[{ "node": "Send Email 1", "type": "main", "index": 0 }]]
    },
    "Send Email 1": {
      "main": [[{ "node": "Update Status → emailed", "type": "main", "index": 0 }]]
    },
    "Update Status → emailed": {
      "main": [[{ "node": "Log Email 1 Send", "type": "main", "index": 0 }]]
    },
    "Get Day-3 Leads": {
      "main": [[{ "node": "Send Email 2", "type": "main", "index": 0 }]]
    },
    "Get Day-7 Leads": {
